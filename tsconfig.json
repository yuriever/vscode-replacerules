{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "outDir": "out",
        "lib": [
            "es2022"
        ],
        "types": [
            "node",
            "vscode",
            "mocha"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "alwaysStrict": true
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
