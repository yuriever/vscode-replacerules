{
    "name": "text-replace-rule",
    "displayName": "TextReplaceRule",
    "description": "Run regexReplace/literalMap text rewrite pipelines from config",
    "version": "1.0.4",
    "publisher": "Yuriever",
    "engines": {
        "vscode": "^1.116.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/yuriever/vscode-replacerules.git"
    },
    "categories": [
        "Other"
    ],
    "icon": "images/icon.png",
    "keywords": [
        "regex",
        "regular expressions",
        "replace",
        "regreplace"
    ],
    "activationEvents": [
        "onCommand:text-replace-rule.runRule",
        "onCommand:text-replace-rule.runRulePipeline"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "text-replace-rule.runRule",
                "title": "Run Rule...",
                "category": "TextReplaceRule"
            },
            {
                "command": "text-replace-rule.runRulePipeline",
                "title": "Run Rule Pipeline...",
                "category": "TextReplaceRule"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "TextReplaceRule",
            "properties": {
                "text-replace-rule.configPath": {
                    "type": "string",
                    "description": "Path to a JSON or JSONC file containing TextReplaceRule configuration. Supports absolute paths, paths with spaces, ~/ expansion, and workspace-relative paths."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^10.2.1",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1"
    }
}
