{
    "name": "replacerules",
    "displayName": "Replace Rules",
    "description": "Create search/replace rules using Javascript regular expressions",
    "version": "0.4.2",
    "publisher": "bhughes339",
    "engines": {
        "vscode": "^1.90.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bhughes339/vscode-replacerules.git"
    },
    "categories": [
        "Other"
    ],
    "icon": "images/icon.png",
    "keywords": [
        "regex",
        "regular expressions",
        "replace",
        "regreplace"
    ],
    "activationEvents": [
        "onCommand:replacerules.runRule",
        "onCommand:replacerules.runRuleset",
        "onCommand:replacerules.stringifyRegex"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "replacerules.runRule",
                "title": "Run Rule...",
                "category": "Replace Rules"
            },
            {
                "command": "replacerules.runRuleset",
                "title": "Run Ruleset...",
                "category": "Replace Rules"
            },
            {
                "command": "replacerules.stringifyRegex",
                "title": "Stringify regular expression",
                "category": "Replace Rules"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Replace Rules",
            "properties": {
                "replacerules.configPath": {
                    "type": "string",
                    "description": "Path to a JSON file containing Replace Rules configuration. Supports absolute paths, paths with spaces, ~/ expansion, and workspace-relative paths."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^10.2.1",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "typescript": "^6.0.3"
    }
}
